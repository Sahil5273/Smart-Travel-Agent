{
  "name": "smart-travel-agent",
  "version": "1.0.0",
  "description": "Human-in-the-loop travel planning agent with React, Express, Firestore, and Gemini",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:client": "npm run build --prefix client",
    "deploy": "npm run build:client && firebase deploy",
    "deploy:hosting": "npm run build:client && firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:firestore": "firebase deploy --only firestore"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "firebase-tools": "^14.0.0"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^14.1.0",
    "pdfkit": "^0.19.1"
  }
}
